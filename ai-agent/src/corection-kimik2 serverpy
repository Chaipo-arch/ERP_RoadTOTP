
import os
import json
import re
import traceback
from typing import Any, Dict, List, Optional

import requests as http_requests
from flask import Flask, request, jsonify
from ollama import Client

app = Flask(__name__)

# ============================================================
# CONFIGURATION
# ============================================================

ollama_host = os.getenv("OLLAMA_HOST", "http://ollama:11434")
ollama_client = Client(host=ollama_host)

ERP_API_BASE = os.getenv("ERP_API_URL", "http://erp-nginx/api/internal")
OPENAPI_URL = os.getenv("OPENAPI_URL", f"{ERP_API_BASE}/openapi")

OPENAPI_CACHE = None
TOOLS_CACHE = None
TOOLS_DESCRIPTION_CACHE = None

# Liste des préfixes autorisés (doit matcher api.php)
ALLOWED_INTERNAL_PREFIXES = (
    "clients",
    "chantiers",
    "employes",
    "materiels",
    "dashboard/stats",
    "planning/events"
)

# ============================================================
# RÉCUPÉRATION DE L'OPENAPI
# ============================================================

def load_openapi():
    try:
        print(f"[OpenAPI] Chargement : {OPENAPI_URL}")
        r = http_requests.get(OPENAPI_URL, timeout=10)
        r.raise_for_status()
        return r.json()
    except Exception as e:
        print(f"[OpenAPI] Erreur : {e}")
        return None

def get_openapi():
    global OPENAPI_CACHE
    if OPENAPI_CACHE is None:
        OPENAPI_CACHE = load_openapi()
    return OPENAPI_CACHE

# ============================================================
# CONSTRUCTION DES OUTILS (TOOLS)
# ============================================================

def allowed(path: str) -> bool:
    """Vérifie si le chemin API est dans la liste blanche."""
    return any(path == p or path.startswith(p + "/") for p in ALLOWED_INTERNAL_PREFIXES)

def generate_tool_name(method: str, path: str) -> str:
    """
    Génère un nom déterministe pour la fonction basé sur la méthode et le chemin.
    Exemples :
      GET /clients          -> get_clients
      GET /clients/{id}     -> get_clients_by_id
      GET /dashboard/stats  -> get_dashboard_stats
    """
    method_prefix = method.lower()
    # Nettoyage du chemin
    clean = path.strip("/")
    # Remplace les paramètres {xxx} par "by_xxx"
    clean = re.sub(r"\{([^}]+)\}", r"by_\1", clean)
    # Remplace les / et - par des underscores
    clean = clean.replace("/", "_").replace("-", "_")
    # Supprime les underscores multiples
    clean = re.sub(r"_+", "_", clean)
    return f"{method_prefix}_{clean}"

def openapi_to_tools(spec: Dict[str, Any]) -> List[Dict[str, Any]]:
    if not spec:
        return []

    tools = []
    paths = spec.get("paths", {})

    for path, methods in paths.items():
        # Nettoyage du chemin pour correspondre aux routes internes
        clean_path = path.replace("/api/internal", "").replace("/api", "").strip("/")
        
        if not allowed(clean_path):
            continue

        for method, details in methods.items():
            if method.lower() != "get":
                continue

            name = generate_tool_name(method, clean_path)
            summary = details.get("summary", f"Accéder à {clean_path}")
            description = details.get("description", summary)

            params = {"type": "object", "properties": {}, "required": []}

            for p in details.get("parameters", []):
                pname = p.get("name")
                if not pname:
                    continue
                
                # Ignore les paramètres de chemin dans le schema (ils sont gérés séparément)
                if p.get("in") == "path":
                    continue

                schema = p.get("schema") or {}
                params["properties"][pname] = {
                    "type": schema.get("type", "string"),
                    "description": p.get("description", pname)
                }
                if p.get("required"):
                    params["required"].append(pname)

            tool = {
                "type": "function",
                "function": {
                    "name": name,
                    "description": description,
                    "parameters": params,
                    "x-path": clean_path,
                    "x-method": method.upper()
                }
            }
            tools.append(tool)

    return tools

def get_tools():
    global TOOLS_CACHE
    if TOOLS_CACHE is None:
        spec = get_openapi()
        TOOLS_CACHE = openapi_to_tools(spec)
        print(f"[Tools] {len(TOOLS_CACHE)} outils chargés.")
        for t in TOOLS_CACHE:
            print(f"  - {t['function']['name']}: {t['function']['x-method']} {t['function']['x-path']}")
    return TOOLS_CACHE

def build_tools_description(tools: List[Dict[str, Any]]) -> str:
    """Génère une description textuelle des outils pour le prompt système."""
    lines = []
    for tool in tools:
        fn = tool["function"]
        lines.append(f"- {fn['name']}: {fn['description']} (endpoint: {fn['x-method']} /{fn['x-path']})")
        if fn["parameters"]["properties"]:
            lines.append("  Paramètres:")
            for pname, pschema in fn["parameters"]["properties"].items():
                req = " (requis)" if pname in fn["parameters"].get("required", []) else ""
                lines.append(f"    • {pname}: {pschema.get('description', '')}{req}")
    return "\n".join(lines)

def get_tools_description():
    global TOOLS_DESCRIPTION_CACHE
    if TOOLS_DESCRIPTION_CACHE is None:
        tools = get_tools()
        TOOLS_DESCRIPTION_CACHE = build_tools_description(tools) if tools else "Aucun outil disponible."
    return TOOLS_DESCRIPTION_CACHE

# ============================================================
# EXÉCUTION DES APPELS API
# ============================================================

def call_api(endpoint, params=None):
    try:
        url = f"{ERP_API_BASE.rstrip('/')}/{endpoint.lstrip('/')}"
        print(f"[API Call] {url} | params={params}")
        r = http_requests.get(url, params=params, timeout=15)
        r.raise_for_status()
        return r.json()
    except Exception as e:
        print(f"[API Error] {e}")
        return {"error": f"Erreur lors de l'appel API : {str(e)}"}

def exec_tool(name, args, tools):
    tool = next((t for t in tools if t["function"]["name"] == name), None)
    if not tool:
        return {"error": f"Outil '{name}' non trouvé."}

    # Nettoyage des arguments
    if isinstance(args, str):
        try:
            args = json.loads(args)
        except:
            args = {}
    if not isinstance(args, dict):
        args = {}

    path = tool["function"]["x-path"]
    
    # Gestion des paramètres de chemin (ex: {id})
    path_params = re.findall(r"\{([^}]+)\}", path)
    for p in path_params:
        if p in args:
            path = path.replace(f"{{{p}}}", str(args[p]))
            del args[p]
        else:
            return {"error": f"Paramètre de chemin requis manquant : {p}"}

    return call_api(path, args)

# ============================================================
# VALIDATION DES TOOL CALLS
# ============================================================

def validate_tool_calls(msg: Dict[str, Any], tools: List[Dict[str, Any]]) -> Optional[str]:
    """Valide que tous les tool_calls demandés existent dans la liste des outils."""
    tool_names = {t["function"]["name"] for t in tools}
    for tc in msg.get("tool_calls", []):
        fn = tc.get("function", {})
        name = fn.get("name")
        if name not in tool_names:
            return f"L'agent a demandé l'outil '{name}' qui n'existe pas. Outils disponibles: {', '.join(tool_names)}"
    return None

# ============================================================
# PROMPT SYSTÈME DYNAMIQUE
# ============================================================

def build_system_prompt() -> str:
    tools_desc = get_tools_description()
    return f"""Tu es l'assistant technique de l'ERP RoadToTP.
INTERDICTIONS :
- Ne jamais inventer de noms de clients, chantiers, employés ou matériels.
- Ne jamais appeler un outil qui n'est pas listé ci-dessous.
- Ne jamais répondre à des questions hors sujet (météo, sport, actualités, réservations...).

OUTILS DISPONIBLES :
{tools_desc}

PROCESSUS OBLIGATOIRE :
1. Analyse la question de l'utilisateur.
2. Si un outil est pertinent, appelle-le avec les bons paramètres.
3. Utilise UNIQUEMENT les données JSON reçues de l'outil pour répondre.
4. Si l'outil ne renvoie rien ou une erreur, dis que tu ne trouves pas l'info dans la base de données.
5. Pour les questions hors-scope de l'ERP, refuse poliment et rappelle ton rôle.

Réponds en français, de manière concise et professionnelle."""

# ============================================================
# ROUTE PRINCIPALE
# ============================================================

@app.route("/ask", methods=["POST"])
def ask():
    try:
        data = request.get_json(force=True) or {}
        question = data.get("question", "").strip()

        if not question:
            return jsonify({"error": "Question vide"}), 400

        tools = get_tools()
        if not tools:
            return jsonify({"error": "Aucun outil disponible. L'OpenAPI n'a pas pu être chargée."}), 503

        system_prompt = build_system_prompt()
        messages = [
            {"role": "system", "content": system_prompt},
            {"role": "user", "content": question}
        ]

        final_content = "Désolé, je n'ai pas pu traiter votre demande."

        # Boucle de réflexion (Tool Calling) - max 5 itérations
        for i in range(5):
            print(f"[Iteration {i+1}] Envoi à Ollama...")
            try:
                response = ollama_client.chat(
                    model="test:latest",
                    messages=messages,
                    tools=tools
                )
            except Exception as e:
                print(f"[Ollama Error] {e}")
                return jsonify({"error": f"Erreur de communication avec Ollama: {str(e)}"}), 502

            msg = response.get("message", {})
            if not msg:
                return jsonify({"error": "Réponse vide d'Ollama"}), 502

            messages.append(msg)

            # Si pas de tool_calls, on a la réponse finale
            if not msg.get("tool_calls"):
                final_content = msg.get("content", "")
                break

            # Validation des tool_calls
            validation_error = validate_tool_calls(msg, tools)
            if validation_error:
                print(f"[Validation Error] {validation_error}")
                messages.append({
                    "role": "tool",
                    "content": json.dumps({"error": validation_error}, ensure_ascii=False)
                })
                continue

            # Exécution des appels d'outils demandés
            for tc in msg["tool_calls"]:
                fn = tc.get("function", {})
                name = fn.get("name")
                args = fn.get("arguments", {})

                print(f"  -> Exécution outil : {name}({args})")
                result = exec_tool(name, args, tools)

                messages.append({
                    "role": "tool",
                    "content": json.dumps(result, ensure_ascii=False)
                })
        else:
            # Si on sort par la limite de boucle sans réponse finale
            final_content = "Je n'ai pas pu finaliser le traitement après plusieurs tentatives."

        return jsonify({"response": final_content})

    except Exception as e:
        print("[FATAL ERROR]")
        traceback.print_exc()
        return jsonify({"error": str(e)}), 500

@app.route("/health")
def health():
    tools = get_tools()
    return jsonify({
        "status": "ok",
        "tools_loaded": len(tools or []),
        "openapi_available": get_openapi() is not None
    })

if __name__ == "__main__":
    # Préchargement au démarrage
    print("[Startup] Préchargement de l'OpenAPI et des tools...")
    get_tools()
    app.run(host="0.0.0.0", port=8000, threaded=True)
